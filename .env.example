# ─── BASE DE DATOS ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=eduenglish_user
DB_PASSWORD=TuPasswordSeguro123
DB_NAME=eduenglish_leads

# ─── SERVIDOR ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS (URL de tu Landing Page) ───────────────────────
ALLOWED_ORIGIN=https://tu-landing.netlify.app

# ─── CORREO (Nodemailer + Gmail) ──────────────────────────
