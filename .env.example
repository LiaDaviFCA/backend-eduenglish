MAIL_USER=eduenglish.leads@gmail.com
# Contraseña de aplicación (NO tu contraseña normal):
# Gmail → Cuenta → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
MAIL_PASS=xxxx xxxx xxxx xxxx

# Correo del área comercial que recibirá las notificaciones de nuevos leads
MAIL_VENTAS=ventas@eduenglish.mx

# ─── CRM (HubSpot) ────────────────────────────────────────
# Obtén tu API Key en: https://app.hubspot.com/api-key
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Si prefieres usar un Webhook genérico en lugar de HubSpot API:
